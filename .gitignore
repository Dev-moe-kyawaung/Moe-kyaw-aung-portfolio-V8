# ─────────────────────────────────────────────
# Moe Kyaw Aung — Portfolio V8 .gitignore
# ─────────────────────────────────────────────

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories & files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# Node / npm (if ever added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm

# Build outputs (not applicable now, but future-proof)
dist/
build/
out/
.cache/

# Logs
*.log
logs/

# Environment variables
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
*~

# Jekyll build output
_site/
.jekyll-cache/
.jekyll-metadata

# Python
__pycache__/
*.py[cod]
*.pyo
